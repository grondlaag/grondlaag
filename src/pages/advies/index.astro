---
import { getCollection } from 'astro:content';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt, sortByManualOrder } from '../../utils/content';

const adviceItems = sortByManualOrder(await getCollection('advies'));
---

<Layout title="advies | grondlaag" description="Praktisch advies rond digitale structuur voor architecten.">
	<main class="listing-page container">
		<header class="listing-header">
			<h1>advies</h1>
			<p class="listing-intro">
				Gerichte begeleiding rond je digitale werking. We kijken naar hoe informatie vandaag wordt opgebouwd, gebruikt en doorgegeven, en waar samenhang ontbreekt. Niet als theorie, maar als basis voor concrete ingrepen.
			</p>
		</header>

		<div class="service-grid">
			{adviceItems.map((item) => (
				<ServiceCard
					title={item.data.title}
					description={getExcerpt(item.body, item.data.description)}
					href={`/grondlaag/advies/${item.id}/`}
					meta={item.data.price}
					category={item.data.category}
					accent={item.data.accent}
				/>
			))}
		</div>
	</main>
</Layout>
