---
import Layout from '../../layouts/Layout.astro';

const adviceItems = [
	{
		title: 'informatiestromen scherpzetten',
		description: 'nagaan waar model, bestek, meetstaat en documentatie elkaar verliezen.',
	},
	{
		title: 'werkafspraken verhelderen',
		description: 'kleine duidelijke afspraken rond naamgeving, revisies, exports en overdracht.',
	},
	{
		title: 'controlepunten inbouwen',
		description: 'lichte checks om inconsistenties vroeger zichtbaar te maken in het proces.',
	},
];
---

<Layout title="advies | grondlaag" description="Praktisch advies rond digitale structuur voor architecten.">
	<main class="listing-page container">
		<header class="listing-header">
			<p class="eyebrow">dienst</p>
			<h1>advies</h1>
			<p class="listing-intro">
				Praktisch advies voor bureaus die meer samenhang willen tussen model, bestek, meetstaat en documentatie.
			</p>
		</header>

		<div class="listing-grid">
			{adviceItems.map((item) => (
				<article class="listing-card">
					<h2>{item.title}</h2>
					<p>{item.description}</p>
				</article>
			))}
		</div>
	</main>
</Layout>
