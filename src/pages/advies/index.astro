---
import { getCollection } from 'astro:content';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt } from '../../utils/content';

const adviceItems = (await getCollection('advies')).sort(
	(a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
);
---

<Layout title="advies | grondlaag" description="Praktisch advies rond digitale structuur voor architecten.">
	<main class="listing-page container">
		<header class="listing-header">
			<h1>advies</h1>
			<p class="listing-intro">
				Adviesfiches rond digitale structuur, werkafspraken en controlepunten die bruikbaar zijn in de dagelijkse praktijk.
			</p>
		</header>

		<div class="service-grid">
			{adviceItems.map((item) => (
				<ServiceCard
					title={item.data.title}
					description={getExcerpt(item.body, item.data.description)}
					href={`/grondlaag/advies/${item.id}/`}
					meta={item.data.price}
				/>
			))}
		</div>
	</main>
</Layout>
