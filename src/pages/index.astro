---
import Hero from '../components/Hero.astro';
import PillarCard from '../components/PillarCard.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';

const pillars = [
	{
		title: 'Advies',
		description:
			'Praktisch advies om digitale informatiestromen in ontwerp, bestek en meetstaat helder op elkaar af te stemmen.',
	},
	{
		title: 'Opleidingen',
		description:
			'Gerichte opleidingen voor teams die minder tijd willen verliezen aan zoeken, dubbel werk en versnipperde afspraken.',
	},
	{
		title: 'Allaambak',
		description:
			'Een concrete toolkit met kleine formats, checks en mini-tools die meteen inzetbaar zijn in lopende projecten.',
	},
];

const allaambakItems = [
	{
		label: 'pdf annotatie pack',
		description: 'vaste markups en commentstijlen voor feedbackrondes, revisies en overdrachten.',
	},
	{
		label: 'obsidian templates',
		description: 'lichte templates voor notities, overlegverslagen, issues en projectafspraken.',
	},
	{
		label: 'bestandsnaam conventies',
		description: 'heldere naamregels voor modellen, exports, revisies en gedeelde documentatie.',
	},
	{
		label: 'excel sanity checks',
		description: 'snelle controles op totalen, ontbrekende regels, dubbele posten en afwijkingen.',
	},
	{
		label: 'gh/python mini-tools',
		description: 'kleine scripts voor repetitieve taken, exports, controles en eenvoudige automatisering.',
	},
	{
		label: 'branded packs',
		description: 'basissets met logo, titelblokken, coverpagina\'s en consistente projectdocumenten.',
	},
];

const whyGroundlaag = [
	{
		title: 'geen softwarepush',
		description:
			'geen verkoopverhaal rond nieuwe tools, maar een nuchtere blik op wat in je huidige werking al beter kan aansluiten.',
	},
	{
		title: 'praktijk boven theorie',
		description:
			'vertrekpunt is het dagelijkse projectwerk: wat moet kloppen tussen model, bestek, meetstaat en documentatie.',
	},
	{
		title: 'kleine gerichte ingrepen',
		description:
			'liever gerichte aanpassingen met direct effect dan zware transformatietrajecten die veel vragen en weinig landen.',
	},
];
---

<Layout>
	<main>
		<Hero
			title="grondlaag"
			subtitle="digitale structuur voor architecten"
			text="grondlaag brengt model, bestek, meetstaat en documentatie terug in dezelfde lijn. helder opgebouwd, technisch leesbaar en bruikbaar in uitvoering."
			ctaHref="mailto:grondlaag@proton.me"
			ctaLabel="grondlaag@proton.me"
		/>

		<Section
			id="probleem"
			title="Het probleem"
			intro="In veel projecten werken model, bestek en meetstaat naast elkaar in plaats van met elkaar."
		>
			<div class="problem-grid">
				<p>
					Informatie wordt op meerdere plaatsen bijgehouden, verschilt van document tot document en verliest onderweg haar context.
				</p>
				<p>
					Dat zorgt voor tijdverlies, dubbel werk en extra controle, net op de momenten waarop duidelijkheid het belangrijkst is.
				</p>
			</div>
		</Section>

		<Section
			id="pijlers"
			title="Drie pijlers"
			intro="Grondlaag bouwt aan een rustige, werkbare digitale basis via drie complementaire sporen."
		>
			<div class="pillar-grid">
				{pillars.map((pillar) => <PillarCard {...pillar} />)}
			</div>
		</Section>

		<Section
			id="waarom-grondlaag"
			title="waarom grondlaag"
			intro="de insteek blijft bewust klein, praktisch en gericht op samenhang in echte projectomgevingen."
		>
			<div class="why-grid">
				{whyGroundlaag.map((item) => <PillarCard {...item} />)}
			</div>
		</Section>

		<Section
			id="allaambak"
			title="allaambak"
			intro="geen losse downloads om te verzamelen, maar bruikbare hulpmiddelen die direct iets oplossen in de dagelijkse werking."
		>
			<div class="tool-grid">
				{allaambakItems.map((item) => (
					<article class="tool-card">
						<p class="tool-card__label">{item.label}</p>
						<p>{item.description}</p>
					</article>
				))}
			</div>
		</Section>

		<Section id="contact" title="Contact">
			<p class="contact-line">
				Neem vrijblijvend contact op via <a href="mailto:grondlaag@proton.me">grondlaag@proton.me</a>.
			</p>
		</Section>
	</main>
</Layout>
