---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="inzichten | grondlaag" description="Artikels en observaties van grondlaag.">
	<main class="listing-page container">
		<header class="listing-header">
			<p class="eyebrow">inhoud</p>
			<h1>inzichten</h1>
			<p class="listing-intro">
				Korte artikels over model, bestek, meetstaat en documentatie in de dagelijkse praktijk.
			</p>
		</header>

		<div class="listing-grid">
			{posts.map((post) => (
				<a class="listing-link" href={`/grondlaag/inzichten/${post.id}/`}>
					<article class="listing-card">
						<p class="listing-meta">{post.data.date.toLocaleDateString('nl-BE')}</p>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
					</article>
				</a>
			))}
		</div>
	</main>
</Layout>
