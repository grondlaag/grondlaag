---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt } from '../../utils/content';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="artikels | grondlaag" description="Overzicht van artikels en observaties van grondlaag.">
	<main class="listing-page container">
		<header class="listing-header">
			<p class="eyebrow">inhoud</p>
			<h1>artikels</h1>
			<p class="listing-intro">
				Korte observaties over digitale projectwerking. Momenten waarop iets zichtbaar wordt: waar systemen beginnen te wringen, of net werken. Meestal klein, soms fundamenteel.
			</p>
		</header>

		<div class="article-listing">
			{posts.map((post) => (
				<ArticleCard
					title={post.data.title}
					description={getExcerpt(post.body, post.data.description)}
					href={`/grondlaag/inzichten/${post.id}/`}
					date={post.data.date}
				/>
			))}
		</div>
	</main>
</Layout>
