---
import { getCollection } from 'astro:content';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt, sortByManualOrder } from '../../utils/content';

const opleidingen = sortByManualOrder(await getCollection('opleidingen'));

function getStatusPresentation(status?: string) {
	switch (status?.toLowerCase()) {
		case 'beschikbaar':
			return { label: 'beschikbaar', tone: 'available' as const };
		case 'volzet':
			return { label: 'volzet', tone: 'full' as const };
		case 'voorzien':
		case 'binnenkort':
			return { label: 'binnenkort', tone: 'soon' as const };
		default:
			return undefined;
	}
}
---

<Layout
	title="opleidingen | grondlaag"
	description="Overzicht van opleidingen en sessies van grondlaag."
>
	<main class="listing-page container">
		<header class="listing-header">
			<h1>opleidingen</h1>
			<p class="listing-intro">Gerichte avondsessies rond afgebakende thema’s. Geen brede opleidingen, maar specifieke onderwerpen die vaak impliciet blijven in projectwerking. We maken zichtbaar hoe ze werken en hoe je er bewuster mee omgaat.</p>
		</header>

		<div class="service-grid">
			{opleidingen.map((opleiding) => {
				const status = getStatusPresentation(opleiding.data.status);

				return (
					<ServiceCard
						title={opleiding.data.title}
						description={getExcerpt(opleiding.body, opleiding.data.description)}
						href={`/grondlaag/opleidingen/${opleiding.id}/`}
						meta={opleiding.data.price}
						category={opleiding.data.category}
						status={status?.label}
						statusTone={status?.tone}
						accent={opleiding.data.accent}
					/>
				);
			})}
		</div>
	</main>
</Layout>
