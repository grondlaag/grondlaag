---
import { getCollection } from 'astro:content';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt, sortByManualOrder } from '../../utils/content';

const items = sortByManualOrder(await getCollection('alaambak'));

function getStatusPresentation(status?: string) {
	switch (status?.toLowerCase()) {
		case 'beschikbaar':
			return { label: 'beschikbaar', tone: 'available' as const };
		case 'volzet':
			return { label: 'volzet', tone: 'full' as const };
		case 'voorzien':
		case 'binnenkort':
		case 'in opbouw':
			return { label: 'binnenkort', tone: 'soon' as const };
		default:
			return undefined;
	}
}
---

<Layout title="alaambak | grondlaag" description="Overzicht van kleine tools en hulpmiddelen van grondlaag.">
	<main class="listing-page container">
		<header class="listing-header">
			<h1>alaambak</h1>
			<p class="listing-intro">
				Kleine hulpmiddelen en eenvoudige tools. Geen grote systemen, maar compacte ingrepen die iets duidelijker, sneller of leesbaarder maken in de praktijk. Wat hier zit, is meestal klein. Maar net daarom bruikbaar.
			</p>
		</header>

		<div class="service-grid">
			{items.map((item) => {
				const status = getStatusPresentation(item.data.status);

				return (
					<ServiceCard
						title={item.data.title}
						description={getExcerpt(item.body, item.data.description)}
						href={`/grondlaag/alaambak/${item.id}/`}
						meta={item.data.price}
						category={item.data.category}
						status={status?.label}
						statusTone={status?.tone}
						accent={item.data.accent}
					/>
				);
			})}
		</div>
	</main>
</Layout>
