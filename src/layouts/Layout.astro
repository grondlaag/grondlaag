---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

interface Props {
	title?: string;
	description?: string;
	theme?:
		| 'default'
		| 'rebels-dichtbij'
		| 'rebels-onredelijk'
		| 'rebels-clever';
}

const {
	title = 'Grondlaag | Digitale structuur voor architecten',
	description = 'Grondlaag brengt digitale structuur in ontwerp-, bestek- en meetstaatprocessen voor architecten.',
	theme = 'default',
} = Astro.props;
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class:list={['site-shell', `theme-${theme}`]}>
		<Navigation />
		<slot />
		<footer class="site-footer">
			<div class="container site-footer__inner">
				<p class="site-footer__note">
					grondlaag verwerkt contact- en boekingsgegevens alleen voor contact, opvolging en planning.
					boekingen verlopen via <a href="https://cal.eu/grondlaag/snelle-babbel">Cal</a>.
					betalingen verlopen, indien van toepassing, via een externe partner.
				</p>
				<div class="site-footer__links" aria-label="footer">
					<a href="/grondlaag/privacy">privacy</a>
					<a href="mailto:grondlaag@proton.me">contact</a>
				</div>
			</div>
		</footer>
	</body>
</html>
