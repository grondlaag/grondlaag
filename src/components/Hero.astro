---
interface Props {
	title: string;
	subtitle: string;
	text: string;
	ctaHref: string;
	ctaLabel: string;
	secondaryCtaHref?: string;
	secondaryCtaLabel?: string;
}

const { title, subtitle, text, ctaHref, ctaLabel, secondaryCtaHref, secondaryCtaLabel } = Astro.props;
---

<section class="hero">
	<div class="hero__inner container">
		<div class="hero__content">
			<p class="eyebrow">{subtitle}</p>
			<h1>{title}</h1>
			<p class="hero__text">{text}</p>
			<div class="hero__actions">
				<a class="button" href={ctaHref}>{ctaLabel}</a>
				{secondaryCtaHref && secondaryCtaLabel && (
					<a class="button button--secondary" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
				)}
			</div>
		</div>
	</div>
</section>
