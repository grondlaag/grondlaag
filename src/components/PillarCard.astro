---
interface Props {
	title: string;
	description: string;
	href?: string;
}

const { title, description, href } = Astro.props;
---

{
	href ? (
		<a class="pillar-card pillar-card--link" href={href}>
			<h3>{title}</h3>
			<p>{description}</p>
		</a>
	) : (
		<article class="pillar-card">
			<h3>{title}</h3>
			<p>{description}</p>
		</article>
	)
}
